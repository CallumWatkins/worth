{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Worth",
  "version": "0.0.1",
  "identifier": "app.useworth",
  "build": {
    "beforeBuildCommand": "bun run generate",
    "frontendDist": "../dist",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Worth",
        "width": 1400,
        "height": 900,
        "minWidth": 850,
        "minHeight": 300,
        "center": true,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#09090B"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExNTlERjhDQzVBQTJFRUEKUldUcUxxckZqTjlab2NZazVyZU14SHVoL0ZCVmpNUFc2MzZudklTcWdkMFBXUmhIdlFEaVVuTE0K",
      "endpoints": [
        "https://releases.useworth.app/v1/update/stable/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
