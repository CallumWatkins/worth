{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccountSnapshotWriteInput",
  "type": "object",
  "properties": {
    "balance_minor": {
      "type": "integer",
      "format": "int64",
      "maximum": 99999999999999,
      "minimum": -99999999999999,
      "x-validation": {
        "maximum": "Balance is too large",
        "minimum": "Balance is too large",
        "required": "Enter a balance",
        "type": "Enter a balance"
      }
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "overwrite_existing": {
      "type": "boolean"
    }
  },
  "required": [
    "date",
    "balance_minor",
    "overwrite_existing"
  ]
}
