{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppSettingsUpdateInput",
  "type": "object",
  "properties": {
    "analytics_enabled": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "default_display_currency_code": {
      "anyOf": [
        {
          "$ref": "#/$defs/CurrencyCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "display_locale": {
      "anyOf": [
        {
          "$ref": "#/$defs/AppLocaleCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "theme": {
      "anyOf": [
        {
          "$ref": "#/$defs/ThemePreference"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "AppLocaleCode": {
      "type": "string",
      "enum": [
        "system",
        "en-GB"
      ]
    },
    "CurrencyCode": {
      "type": "string",
      "enum": [
        "GBP"
      ]
    },
    "ThemePreference": {
      "type": "string",
      "enum": [
        "system",
        "light",
        "dark"
      ]
    }
  }
}
