{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccountUpsertInput",
  "type": "object",
  "properties": {
    "account_classification": {
      "$ref": "#/$defs/AccountClassification",
      "x-validation": {
        "invalid": "Select a balance type",
        "required": "Select a balance type",
        "type": "Select a balance type"
      }
    },
    "account_type": {
      "$ref": "#/$defs/AccountTypeName",
      "x-validation": {
        "invalid": "Select an account type",
        "required": "Select an account type",
        "type": "Select an account type"
      }
    },
    "closed_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "currency_code": {
      "$ref": "#/$defs/CurrencyCode",
      "x-validation": {
        "invalid": "Select a currency",
        "required": "Select a currency",
        "type": "Select a currency"
      }
    },
    "institution": {
      "$ref": "#/$defs/InstitutionRef",
      "x-validation": {
        "invalid": "Select or create an institution",
        "required": "Select or create an institution",
        "type": "Select or create an institution"
      }
    },
    "name": {
      "type": "string",
      "maxLength": 80,
      "minLength": 1,
      "pattern": ".*\\S.*",
      "x-validation": {
        "blank": "Enter an account name",
        "maxLength": "Account name must be 80 characters or fewer",
        "required": "Enter an account name",
        "type": "Enter an account name"
      }
    },
    "opened_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    }
  },
  "required": [
    "institution",
    "name",
    "account_type",
    "currency_code",
    "account_classification"
  ],
  "$defs": {
    "AccountClassification": {
      "type": "string",
      "enum": [
        "asset",
        "liability"
      ]
    },
    "AccountTypeName": {
      "type": "string",
      "enum": [
        "current",
        "savings",
        "credit_card",
        "isa",
        "investment",
        "pension",
        "cash",
        "loan"
      ]
    },
    "CurrencyCode": {
      "type": "string",
      "enum": [
        "GBP"
      ]
    },
    "InstitutionRef": {
      "discriminator": {
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "format": "int64",
              "minimum": 1,
              "x-validation": {
                "minimum": "Select or create an institution",
                "required": "Select or create an institution",
                "type": "Select or create an institution"
              }
            },
            "kind": {
              "type": "string",
              "const": "existing"
            }
          },
          "required": [
            "kind",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "input": {
              "$ref": "#/$defs/InstitutionUpsertInput"
            },
            "kind": {
              "type": "string",
              "const": "new"
            }
          },
          "required": [
            "kind",
            "input"
          ]
        }
      ]
    },
    "InstitutionUpsertInput": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 80,
          "minLength": 1,
          "pattern": ".*\\S.*",
          "x-validation": {
            "blank": "Enter an institution name",
            "maxLength": "Institution name must be 80 characters or fewer",
            "required": "Enter an institution name",
            "type": "Enter an institution name"
          }
        }
      },
      "required": [
        "name"
      ]
    }
  }
}
