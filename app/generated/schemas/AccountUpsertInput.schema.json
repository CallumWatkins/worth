{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AccountUpsertInput",
  "type": "object",
  "required": [
    "account_type",
    "currency_code",
    "institution",
    "name",
    "normal_balance_sign"
  ],
  "properties": {
    "account_type": {
      "$ref": "#/definitions/AccountTypeName"
    },
    "currency_code": {
      "type": "string",
      "maxLength": 3,
      "minLength": 3,
      "pattern": "^[A-Z]{3}$"
    },
    "institution": {
      "$ref": "#/definitions/InstitutionRef"
    },
    "name": {
      "type": "string",
      "maxLength": 120,
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "normal_balance_sign": {
      "type": "integer",
      "oneOf": [
        {
          "const": -1
        },
        {
          "const": 1
        }
      ]
    },
    "opened_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    }
  },
  "definitions": {
    "AccountTypeName": {
      "type": "string",
      "enum": [
        "current",
        "savings",
        "credit_card",
        "isa",
        "investment",
        "pension",
        "cash",
        "loan"
      ]
    },
    "InstitutionRef": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "id",
            "kind"
          ],
          "properties": {
            "id": {
              "type": "integer",
              "format": "int64",
              "minimum": 1.0
            },
            "kind": {
              "type": "string",
              "enum": [
                "existing"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "input",
            "kind"
          ],
          "properties": {
            "input": {
              "$ref": "#/definitions/InstitutionUpsertInput"
            },
            "kind": {
              "type": "string",
              "enum": [
                "new"
              ]
            }
          }
        }
      ]
    },
    "InstitutionUpsertInput": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 120,
          "minLength": 1,
          "pattern": ".*\\S.*"
        }
      }
    }
  }
}
