{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AccountUpsertInput",
  "type": "object",
  "properties": {
    "account_type": {
      "$ref": "#/$defs/AccountTypeName"
    },
    "currency_code": {
      "$ref": "#/$defs/CurrencyCode"
    },
    "institution": {
      "$ref": "#/$defs/InstitutionRef"
    },
    "name": {
      "type": "string",
      "maxLength": 120,
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "normal_balance_sign": {
      "type": "integer",
      "format": "int32",
      "enum": [
        -1,
        1
      ]
    },
    "opened_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    }
  },
  "required": [
    "institution",
    "name",
    "account_type",
    "currency_code",
    "normal_balance_sign"
  ],
  "$defs": {
    "AccountTypeName": {
      "type": "string",
      "enum": [
        "current",
        "savings",
        "credit_card",
        "isa",
        "investment",
        "pension",
        "cash",
        "loan"
      ]
    },
    "CurrencyCode": {
      "type": "string",
      "enum": [
        "GBP"
      ]
    },
    "InstitutionRef": {
      "discriminator": {
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            },
            "kind": {
              "type": "string",
              "const": "existing"
            }
          },
          "required": [
            "kind",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "input": {
              "$ref": "#/$defs/InstitutionUpsertInput"
            },
            "kind": {
              "type": "string",
              "const": "new"
            }
          },
          "required": [
            "kind",
            "input"
          ]
        }
      ]
    },
    "InstitutionUpsertInput": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 120,
          "minLength": 1,
          "pattern": ".*\\S.*"
        }
      },
      "required": [
        "name"
      ]
    }
  }
}
