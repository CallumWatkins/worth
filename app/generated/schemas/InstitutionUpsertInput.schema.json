{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InstitutionUpsertInput",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 120,
      "minLength": 1,
      "pattern": ".*\\S.*",
      "x-validation": {
        "blank": "Enter an institution name",
        "maxLength": "Institution name must be 120 characters or fewer",
        "required": "Enter an institution name",
        "type": "Enter an institution name"
      }
    }
  },
  "required": [
    "name"
  ]
}
