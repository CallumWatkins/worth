{
  "name": "@callumwatkins/worth",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "A balance tracking desktop app",
  "author": "Callum Watkins <callum@callumwatkins.com> (https://www.callumwatkins.com)",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preinstall": "npx only-allow bun",
    "postinstall": "nuxt prepare",
    "check:ts": "nuxt typecheck",
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint . --fix",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml --all-targets --features dev-tools",
    "lint:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --features dev-tools",
    "lint:rust:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --features dev-tools --fix && cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "check:all": "bun run --parallel check:ts check:rust",
    "lint:all": "bun run --parallel lint:ts lint:rust",
    "lint:all:fix": "bun run --sequential lint:ts:fix lint:rust:fix",
    "bump": "bumpp",
    "db": "cargo run --manifest-path src-tauri/Cargo.toml --features dev-tools --bin db --",
    "contracts:bindings": "cargo run --manifest-path src-tauri/Cargo.toml --features dev-tools --bin export_bindings",
    "contracts:schemas": "cargo run --manifest-path src-tauri/Cargo.toml --features dev-tools --bin export_schemas",
    "contracts:zod": "bun run app/scripts/generate-zod.mjs",
    "contracts:gen": "bun run --sequential contracts:bindings contracts:schemas contracts:zod",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug --config src-tauri/tauri.dev.conf.json"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.0.0",
    "@internationalized/date": "=3.12.1",
    "@number-flow/vue": "^0.5.0",
    "@nuxt/ui": "^4.0.0",
    "@nuxtjs/i18n": "^10.0.0",
    "@posthog/nuxt": "^1.0.0",
    "@tanstack/vue-query": "^5.0.0",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-opener": "=2.5.4",
    "@tauri-apps/plugin-process": "=2.3.1",
    "default-passive-events": "^4.0.0",
    "echarts": "^6.0.0",
    "nuxt": "^4.0.0",
    "nuxt-echarts": "^1.0.0",
    "semver": "^7.0.0",
    "vue": "^3.0.0",
    "vue-echarts": "^8.0.0",
    "vue-router": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@apidevtools/json-schema-ref-parser": "^15.0.0",
    "@nuxt/eslint": "^1.0.0",
    "@tauri-apps/cli": "~2.11.0",
    "@types/semver": "^7.0.0",
    "@vueuse/core": "^14.0.0",
    "@vueuse/nuxt": "^14.0.0",
    "bumpp": "^11.0.0",
    "eslint": "^10.0.0",
    "json-schema-to-zod": "^2.0.0",
    "typescript": "^6.0.0",
    "vue-tsc": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "unrs-resolver"
  ]
}
