{
  "name": "@callumwatkins/worth",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.5",
  "description": "A balance tracking desktop app",
  "author": "Callum Watkins <callum@callumwatkins.com> (https://www.callumwatkins.com)",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preinstall": "npx only-allow bun",
    "postinstall": "nuxt prepare",
    "check:ts": "nuxt typecheck",
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint . --fix",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "lint:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml",
    "lint:rust:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --fix && cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "check:all": "bun run check:ts && bun run check:rust",
    "lint:all": "bun run lint:ts && bun run lint:rust",
    "lint:all:fix": "bun run lint:ts:fix && bun run lint:rust:fix",
    "bump": "bumpp",
    "db": "cargo run --manifest-path src-tauri/Cargo.toml --bin db --",
    "contracts:bindings": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_bindings",
    "contracts:schemas": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_schemas",
    "contracts:zod": "bun run app/scripts/generate-zod.mjs",
    "contracts:gen": "bun run contracts:bindings && bun run contracts:schemas && bun run contracts:zod",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug"
  },
  "dependencies": {
    "@internationalized/date": "3.10.1",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@tanstack/vue-query": "^5.92.9",
    "@tauri-apps/api": "^2.9.1",
    "echarts": "^6.0.0",
    "nuxt": "^4.2.2",
    "nuxt-echarts": "1.0.1",
    "vue": "^3.5.26",
    "vue-echarts": "^8.0.0",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@apidevtools/json-schema-ref-parser": "^15.2.2",
    "@nuxt/eslint": "^1.12.1",
    "@tauri-apps/cli": "^2.9.6",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "json-schema-to-zod": "^2.7.0",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "typescript": "npm:tslite@latest"
  },
  "overrides": {
    "@internationalized/date": "3.10.1"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "unrs-resolver"
  ]
}
